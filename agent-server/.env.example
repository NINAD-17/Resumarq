# MongoDB
MONGODB_URI=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET_NAME=

# Google Gemini API
GOOGLE_API_KEY=

# Model names (optional — defaults in config.py are used if not set)
GEMINI_PARSER_MODEL=gemini-3.5-flash
GEMINI_AUDIT_MODEL=gemini-3.5-flash
GEMINI_CRITIC_MODEL=gemini-3.5-flash

# Internal API key (must match AGENT_SERVER_KEY in web/.env.local)
API_KEY=
