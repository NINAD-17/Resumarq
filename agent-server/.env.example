# MongoDB
MONGODB_URI=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET_NAME=

# Google Gemini API
GOOGLE_API_KEY=

# Model configuration (optional — defaults in config.py are used if not set)
MODEL_PROVIDER=google_genai
MODEL_LITE=gemini-3.5-flash
MODEL_FLASH=gemini-3.5-flash
MODEL_PRO=gemini-3.5-flash

# Internal API key (must match AGENT_SERVER_KEY in web/.env.local)
API_KEY=
