# ============================================================
# Resumarq — Gitignore (monorepo: Next.js + FastAPI)
# ============================================================

# ==========================
# Environment & Secrets
# ==========================
.env
.env.*
.envrc
!.env.example

# ==========================
# Node.js / JavaScript
# ==========================

# Dependencies
node_modules/

# Package manager locks (keep only the one you use)
# Uncomment the ones you DON'T use:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Yarn (v1 and v3+)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*
.yarn-integrity

# pnpm
.pnpm-store

# npm
.npm

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build & output
build/
dist/
out/

# Next.js
.next/
next-env.d.ts

# Vercel
.vercel

# Testing & coverage
coverage/
*.lcov
.nyc_output/

# TypeScript
*.tsbuildinfo

# ESLint & Prettier
.eslintcache
.stylelintcache

# Misc
*.tgz
*.pem

# ==========================
# Python
# ==========================

# Byte-compiled / optimized
__pycache__/
*.py[codz]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
sdist/
wheels/
*.whl

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
nosetests.xml
coverage.xml

# Type checkers
.mypy_cache/
.pytype/
.pyre/
.dmypy.json

# Ruff
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# ==========================
# Docker
# ==========================
docker-compose.override.yml

# ==========================
# OS / IDE
# ==========================

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# VS Code (uncomment to ignore workspace settings)
# .vscode/

# JetBrains (uncomment to ignore)
# .idea/